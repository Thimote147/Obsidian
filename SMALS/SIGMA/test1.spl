# Title: Suspicious Sudo Usage and Configuration Access
# ID: 8d8a8d91-7b4c-4c8f-9e4a-1f3c4d5e6f7a
# Description: Detects suspicious sudo command usage, sudoers file access, and potential privilege escalation attempts
# Level: medium
# Author: Thimoté Fétu
# Date: 2026/02/25
# Tags: attack.privilege_escalation, attack.defense_evasion, attack.t1548.003
# Index: *_linux
#
# Splunk Query:
index=*_linux (type="EXECVE" a0="sudo" a1="-l" OR type="EXECVE" (a0=*cat* OR a0=*less* OR a0=*more* OR a0=*tail* OR a0=*head*) a1=*/etc/sudoers* OR type="EXECVE" (a0=*vim* OR a0=*vi* OR a0=*nano* OR a0=*emacs*) a1=*/etc/sudoers* OR type="EXECVE" a0="sudo" (a1=*bash* OR a1=*sh* OR a1=*/bin/sh* OR a1=*/bin/bash* OR a1=*zsh*) OR type="EXECVE" a0="sudo" (a1=*find* OR a1=*awk* OR a1=*python* OR a1=*perl* OR a1=*ruby* OR a1=*less* OR a1=*more* OR a1=*vim*) (a2=*-exec* OR a2=*system* OR a2=*BEGIN* OR a2=*!sh*))
